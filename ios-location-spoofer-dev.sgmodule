#!name=iOS Location Spoofer Dev Raw
#!desc=DEV diagnostic module. Spoofs Apple Park while dumping full /clls/wloc request, original response, and patched response bodies as base64 chunks.
#!author=Codex port, original research/code by acheong08
#!homepage=https://github.com/acheong08/ios-location-spoofer

[Script]
# Request side: pass through Apple's request, dump the raw ARPC request body,
# and force identity encoding where Shadowrocket allows header rewriting.
iOS Location Spoofer Dev Request Raw = type=http-request,pattern=^https?:\/\/(?:gs-loc(?:-cn)?\.apple\.com|bluedot\.is\.autonavi\.com(?:\.gds\.alibabadns\.com)?)\/clls\/wloc(?:\?.*)?$,requires-body=1,binary-body-mode=1,max-size=0,timeout=10,script-path=https://raw.githubusercontent.com/batqwq/shadowrocket-location-spoofer/main/location-spoofer.js,argument=mode=inspect&debug=true&dumpRaw=true&dumpHeaders=true&prepareHeaders=true&rawLimit=0

# Response side: spoof Apple's real response and dump both the original and
# patched binary responses. Apple Park default: 37.3349,-122.00902.
iOS Location Spoofer Dev Response Raw = type=http-response,pattern=^https?:\/\/(?:gs-loc(?:-cn)?\.apple\.com|bluedot\.is\.autonavi\.com(?:\.gds\.alibabadns\.com)?)\/clls\/wloc(?:\?.*)?$,requires-body=1,binary-body-mode=1,max-size=0,timeout=10,script-path=https://raw.githubusercontent.com/batqwq/shadowrocket-location-spoofer/main/location-spoofer.js,argument=mode=response&latitude=37.3349&longitude=-122.00902&horizontalAccuracy=39&verticalAccuracy=1000&altitude=530&debug=true&dumpRaw=true&dumpHeaders=true&rawLimit=0

[MITM]
hostname = %APPEND% gs-loc.apple.com, gs-loc-cn.apple.com, bluedot.is.autonavi.com, bluedot.is.autonavi.com.gds.alibabadns.com
